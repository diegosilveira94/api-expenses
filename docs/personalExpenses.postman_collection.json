              "path": ["dashboard", "expenses-count"]
            }
          }
        },
        {
          "name": "Expenses by category (GET /dashboard/expenses-by-category)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/dashboard/expenses-by-category",
